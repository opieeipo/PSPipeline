{
  "name": "customer-order-summary",
  "description": "Join customers to their completed orders and total spend per customer.",
  "version": 1,
  "nodes": [
    {
      "id": "customers",
      "type": "input.csv",
      "label": "Customers (CSV)",
      "position": { "x": 40, "y": 60 },
      "config": { "path": "samples/customers.csv" }
    },
    {
      "id": "orders",
      "type": "input.csv",
      "label": "Orders (CSV)",
      "position": { "x": 40, "y": 240 },
      "config": { "path": "samples/orders.csv" }
    },
    {
      "id": "completed",
      "type": "transform.filter",
      "label": "Completed only",
      "position": { "x": 280, "y": 240 },
      "config": {
        "match": "All",
        "conditions": [
          { "column": "Status", "operator": "eq", "value": "Completed" }
        ]
      }
    },
    {
      "id": "join",
      "type": "transform.join",
      "label": "Customers + Orders",
      "position": { "x": 520, "y": 140 },
      "config": {
        "joinType": "Left",
        "leftKey": "CustomerId",
        "rightKey": "CustomerId"
      }
    },
    {
      "id": "totals",
      "type": "transform.aggregate",
      "label": "Spend per customer",
      "position": { "x": 760, "y": 140 },
      "config": {
        "groupBy": ["CustomerId", "Name", "Region"],
        "aggregations": [
          { "column": "Amount", "function": "Sum", "as": "TotalSpend" },
          { "column": "Amount", "function": "Count", "as": "CompletedOrders" }
        ]
      }
    },
    {
      "id": "sorted",
      "type": "transform.sort",
      "label": "Highest spend first",
      "position": { "x": 1000, "y": 140 },
      "config": {
        "sortBy": [ { "column": "TotalSpend", "descending": true } ]
      }
    },
    {
      "id": "report",
      "type": "output.csv",
      "label": "Summary report",
      "position": { "x": 1240, "y": 140 },
      "config": { "path": "samples/output/customer-order-summary.csv" }
    }
  ],
  "edges": [
    { "from": "customers", "to": "join", "toPort": "left" },
    { "from": "orders", "to": "completed", "toPort": "in" },
    { "from": "completed", "to": "join", "toPort": "right" },
    { "from": "join", "to": "totals", "toPort": "in" },
    { "from": "totals", "to": "sorted", "toPort": "in" },
    { "from": "sorted", "to": "report", "toPort": "in" }
  ]
}
